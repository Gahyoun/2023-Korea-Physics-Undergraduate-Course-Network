        "#!/usr/bin/env python3\n",
        "# -*- coding: utf-8 -*-\n",
        "\n",
        "import gc\n",
        "import json\n",
        "import os\n",
        "import random\n",
        "import time\n",
        "import argparse\n",
        "from pathlib import Path\n",
        "from typing import Any, Dict, List\n",
        "\n",
        "import pandas as pd\n",
        "import torch\n",
        "from peft import PeftModel\n",
        "from transformers import AutoModelForCausalLM, AutoTokenizer\n",
        "\n",
        "from math_answer_policy import (\n",
        "    ANSWER_SYSTEM_PROMPT,\n",
        "    load_items,\n",
        "    is_usable_item,\n",
        "    retrieve_answer_references,\n",
        "    build_math_answer_prompt,\n",
        "    extract_math_answer_payload,\n",
        "    is_valid_math_answer_payload,\n",
        "    objective_answer_matches,\n",
        "    final_answer_matches_reference,\n",
        "    answer_payload_quality_flags,\n",
        "    sympy_equivalent,\n",
        "    sympy_first_screening_on_item,\n",
        "    get_source_item_id,\n",
        "    get_stem_text,\n",
        "    get_answer_text,\n",
        "    get_level_id,\n",
        "    get_subject,\n",
        "    get_chapter,\n",
        "    get_unit,\n",
        "    classify_problem_type,\n",
        ")\n",
        "\n",
        "BASE_MODEL = \"meta-llama/Llama-3.1-8B-Instruct\"\n",
        "CONFIG_PATH_DEFAULT = \"/workspace/config/targets_2015.json\"\n",
        "\n",
        "MAX_NEW_TOKENS = 900\n",
        "TEMPERATURE = 0.25\n",
        "TOP_P = 0.9\n",
        "REPETITION_PENALTY = 1.08\n",
        "\n",
        "DEFAULT_SEED = 42\n",
        "DEFAULT_MAX_RETRY = 3\n",
        "DEFAULT_TOP_K_REF = 5\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 설정\n",
        "# =========================\n",
        "def read_json(path: str) -> Dict[str, Any]:\n",
        "    with open(path, \"r\", encoding=\"utf-8\") as f:\n",
        "        return json.load(f)\n",
        "\n",
        "\n",
        "def resolve_target_config(target_id: str, config_path: str) -> Dict[str, Any]:\n",
        "    cfg = read_json(config_path)\n",
        "    if target_id not in cfg:\n",
        "        raise KeyError(f\"target_id not found: {target_id}\")\n",
        "\n",
        "    t = dict(cfg[target_id])\n",
        "    t[\"target_id\"] = target_id\n",
        "    t.setdefault(\"math_answer_model_dir\", f\"/workspace/outputs/math_answer_{target_id}\")\n",
        "    return t\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 모델\n",
        "# =========================\n",
        "def load_model_and_tokenizer(base_model: str, lora_path: str):\n",
        "    hf_token = os.environ.get(\"HF_TOKEN\")\n",
        "    if not hf_token:\n",
        "        raise RuntimeError(\"HF_TOKEN is empty or not set\")\n",
        "\n",
        "    tokenizer = AutoTokenizer.from_pretrained(\n",
        "        base_model,\n",
        "        token=hf_token,\n",
        "        trust_remote_code=True,\n",
        "    )\n",
        "    if tokenizer.pad_token is None:\n",
        "        tokenizer.pad_token = tokenizer.eos_token\n",
        "\n",
        "    model = AutoModelForCausalLM.from_pretrained(\n",
        "        base_model,\n",
        "        token=hf_token,\n",
        "        torch_dtype=torch.bfloat16,\n",
        "        device_map=\"auto\",\n",
        "        trust_remote_code=True,\n",
        "    )\n",
        "    model = PeftModel.from_pretrained(model, lora_path)\n",
        "    model.eval()\n",
        "    return tokenizer, model\n",
        "\n",
        "\n",
        "def generate_one(tokenizer, model, system_prompt: str, user_prompt: str) -> str:\n",
        "    messages = [\n",
        "        {\"role\": \"system\", \"content\": system_prompt},\n",
        "        {\"role\": \"user\", \"content\": user_prompt},\n",
        "    ]\n",
        "\n",
        "    inputs = tokenizer.apply_chat_template(\n",
        "        messages,\n",
        "        tokenize=True,\n",
        "        add_generation_prompt=True,\n",
        "        return_tensors=\"pt\",\n",
        "        return_dict=True,\n",
        "    )\n",
        "\n",
        "    model_device = next(model.parameters()).device\n",
        "    inputs = {k: v.to(model_device) for k, v in inputs.items()}\n",
        "\n",
        "    with torch.no_grad():\n",
        "        outputs = model.generate(\n",
        "            **inputs,\n",
        "            max_new_tokens=MAX_NEW_TOKENS,\n",
        "            do_sample=True,\n",
        "            temperature=TEMPERATURE,\n",
        "            top_p=TOP_P,\n",
        "            repetition_penalty=REPETITION_PENALTY,\n",
        "            pad_token_id=tokenizer.pad_token_id,\n",
        "            eos_token_id=tokenizer.eos_token_id,\n",
        "        )\n",
        "\n",
        "    prompt_len = inputs[\"input_ids\"].shape[1]\n",
        "    gen_tokens = outputs[0][prompt_len:]\n",
        "    return tokenizer.decode(gen_tokens, skip_special_tokens=True)\n",
        "\n",
        "\n",
        "def generate_valid_one(\n",
        "    tokenizer,\n",
        "    model,\n",
        "    user_prompt: str,\n",
        "    reference_answer: str,\n",
        "    max_retry: int = DEFAULT_MAX_RETRY,\n",
        ") -> Dict[str, Any]:\n",
        "    last_raw = \"\"\n",
        "    last_payload: Dict[str, Any] = {}\n",
        "    last_flags: Dict[str, bool] = {}\n",
        "\n",
        "    for trial in range(1, max_retry + 1):\n",
        "        raw = generate_one(tokenizer, model, ANSWER_SYSTEM_PROMPT, user_prompt)\n",
        "        payload = extract_math_answer_payload(raw)\n",
        "\n",
        "        valid = is_valid_math_answer_payload(payload)\n",
        "        obj_match = objective_answer_matches(payload) if valid else False\n",
        "        ref_match = final_answer_matches_reference(payload, reference_answer) if valid else False\n",
        "        flags = answer_payload_quality_flags(payload) if payload else {\"invalid_format\": True}\n",
        "\n",
        "        last_raw = raw\n",
        "        last_payload = payload\n",
        "        last_flags = flags\n",
        "\n",
        "        if valid and obj_match and ref_match:\n",
        "            return {\n",
        "                \"success\": True,\n",
        "                \"retry_count\": trial,\n",
        "                \"raw_output\": raw,\n",
        "                \"payload\": payload,\n",
        "                \"quality_flags\": flags,\n",
        "                \"objective_match\": obj_match,\n",
        "                \"reference_match\": ref_match,\n",
        "            }\n",
        "\n",
        "    return {\n",
        "        \"success\": False,\n",
        "        \"retry_count\": max_retry,\n",
        "        \"raw_output\": last_raw,\n",
        "        \"payload\": last_payload,\n",
        "        \"quality_flags\": last_flags,\n",
        "        \"objective_match\": objective_answer_matches(last_payload) if last_payload else False,\n",
        "        \"reference_match\": final_answer_matches_reference(last_payload, reference_answer) if last_payload else False,\n",
        "    }\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 저장\n",
        "# =========================\n",
        "def save_dataframe_with_fallback(df: pd.DataFrame, xlsx_path: Path) -> Path:\n",
        "    try:\n",
        "        df.to_excel(xlsx_path, index=False)\n",
        "        return xlsx_path\n",
        "    except ModuleNotFoundError:\n",
        "        csv_path = xlsx_path.with_suffix(\".csv\")\n",
        "        df.to_csv(csv_path, index=False, encoding=\"utf-8-sig\")\n",
        "        return csv_path\n",
        "\n",
        "\n",
        "def unload_model(model=None, tokenizer=None):\n",
        "    try:\n",
        "        del model\n",
        "    except Exception:\n",
        "        pass\n",
        "    try:\n",
        "        del tokenizer\n",
        "    except Exception:\n",
        "        pass\n",
        "    gc.collect()\n",
        "    if torch.cuda.is_available():\n",
        "        torch.cuda.empty_cache()\n",
        "        torch.cuda.ipc_collect()\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 메인\n",
        "# =========================\n",
        "def main():\n",
        "    parser = argparse.ArgumentParser(description=\"Test math_answer model and export SymPy-based metrics\")\n",
        "    parser.add_argument(\"--target_id\", type=str, required=True)\n",
        "    parser.add_argument(\"--input_json\", type=str, required=True)\n",
        "    parser.add_argument(\"--ref_json\", type=str, default=\"\")\n",
        "    parser.add_argument(\"--config_path\", type=str, default=CONFIG_PATH_DEFAULT)\n",
        "    parser.add_argument(\"--n_tests\", type=int, default=20)\n",
        "    parser.add_argument(\"--level_id\", type=int, default=-1)\n",
        "    parser.add_argument(\"--top_k_ref\", type=int, default=DEFAULT_TOP_K_REF)\n",
        "    parser.add_argument(\"--seed\", type=int, default=DEFAULT_SEED)\n",
        "    parser.add_argument(\"--max_retry\", type=int, default=DEFAULT_MAX_RETRY)\n",
        "    args = parser.parse_args()\n",
        "\n",
        "    random.seed(args.seed)\n",
        "    torch.manual_seed(args.seed)\n",
        "\n",
        "    target_cfg = resolve_target_config(args.target_id, args.config_path)\n",
        "    model_dir = target_cfg[\"math_answer_model_dir\"]\n",
        "\n",
        "    items = [x for x in load_items(Path(args.input_json)) if is_usable_item(x)]\n",
        "    if args.ref_json.strip():\n",
        "        ref_items = [x for x in load_items(Path(args.ref_json)) if is_usable_item(x)]\n",
        "    else:\n",
        "        ref_items = items\n",
        "\n",
        "    if args.level_id != -1:\n",
        "        items = [x for x in items if get_level_id(x) == args.level_id]\n",
        "\n",
        "    if not items:\n",
        "        raise RuntimeError(\"no candidate item found for test\")\n",
        "\n",
        "    random.shuffle(items)\n",
        "    test_items = items[: min(args.n_tests, len(items))]\n",
        "\n",
        "    print(f\"[INFO] usable items={len(items)}\")\n",
        "    print(f\"[INFO] ref_items={len(ref_items)}\")\n",
        "    print(f\"[INFO] test_items={len(test_items)}\")\n",
        "\n",
        "    tokenizer, model = load_model_and_tokenizer(BASE_MODEL, model_dir)\n",
        "\n",
        "    output_dir = Path(\"/workspace/outputs\")\n",
        "    output_dir.mkdir(parents=True, exist_ok=True)\n",
        "\n",
        "    suffix = f\"{args.target_id}\"\n",
        "    if args.level_id != -1:\n",
        "        suffix += f\"_level{args.level_id}\"\n",
        "\n",
        "    result_json = output_dir / f\"test_math_answer_{suffix}.json\"\n",
        "    result_xlsx = output_dir / f\"test_math_answer_{suffix}.xlsx\"\n",
        "    summary_json = output_dir / f\"test_math_answer_{suffix}_summary.json\"\n",
        "    summary_xlsx = output_dir / f\"test_math_answer_{suffix}_summary.xlsx\"\n",
        "\n",
        "    rows: List[Dict[str, Any]] = []\n",
        "\n",
        "    sympy_equiv_count = 0\n",
        "    valid_payload_count = 0\n",
        "    objective_match_count = 0\n",
        "    reference_match_count = 0\n",
        "    success_count = 0\n",
        "\n",
        "    problem_type_counter: Dict[str, int] = {}\n",
        "    level_counter: Dict[Any, int] = {}\n",
        "\n",
        "    total_start = time.perf_counter()\n",
        "\n",
        "    for i, item in enumerate(test_items, start=1):\n",
        "        t0 = time.perf_counter()\n",
        "\n",
        "        ref_examples = retrieve_answer_references(\n",
        "            ref_items=ref_items,\n",
        "            target_item=item,\n",
        "            top_k=args.top_k_ref,\n",
        "        )\n",
        "        user_prompt, prompt_meta = build_math_answer_prompt(\n",
        "            target_item=item,\n",
        "            ref_examples=ref_examples,\n",
        "        )\n",
        "\n",
        "        ref_answer = get_answer_text(item)\n",
        "\n",
        "        result = generate_valid_one(\n",
        "            tokenizer=tokenizer,\n",
        "            model=model,\n",
        "            user_prompt=user_prompt,\n",
        "            reference_answer=ref_answer,\n",
        "            max_retry=args.max_retry,\n",
        "        )\n",
        "\n",
        "        payload = result.get(\"payload\", {})\n",
        "        final_answer = payload.get(\"final_answer\", \"\")\n",
        "        sympy_eq = sympy_equivalent(final_answer, ref_answer) if final_answer and ref_answer else False\n",
        "\n",
        "        elapsed_sec = time.perf_counter() - t0\n",
        "\n",
        "        valid_payload = is_valid_math_answer_payload(payload) if payload else False\n",
        "        objective_match = result.get(\"objective_match\", False)\n",
        "        reference_match = result.get(\"reference_match\", False)\n",
        "        success = result.get(\"success\", False)\n",
        "\n",
        "        if valid_payload:\n",
        "            valid_payload_count += 1\n",
        "        if objective_match:\n",
        "            objective_match_count += 1\n",
        "        if reference_match:\n",
        "            reference_match_count += 1\n",
        "        if sympy_eq:\n",
        "            sympy_equiv_count += 1\n",
        "        if success:\n",
        "            success_count += 1\n",
        "\n",
        "        ptype = classify_problem_type(item)\n",
        "        lvl = get_level_id(item)\n",
        "        problem_type_counter[ptype] = problem_type_counter.get(ptype, 0) + 1\n",
        "        level_counter[lvl] = level_counter.get(lvl, 0) + 1\n",
        "\n",
        "        row = {\n",
        "            \"idx\": i,\n",
        "            \"source_item_id\": get_source_item_id(item),\n",
        "            \"level_id\": lvl,\n",
        "            \"subject\": get_subject(item),\n",
        "            \"chapter\": get_chapter(item),\n",
        "            \"unit\": get_unit(item),\n",
        "            \"problem_type_detected\": ptype,\n",
        "\n",
        "            # test 원문\n",
        "            \"exam_text\": get_stem_text(item),\n",
        "\n",
        "            # 모범답안 / 모범해설\n",
        "            \"reference_answer_text\": ref_answer,\n",
        "            \"reference_explanation_text\": get_explanation_text(item),\n",
        "\n",
        "            # retrieval\n",
        "            \"retrieved_reference_item_ids\": [get_source_item_id(x) for x in ref_examples],\n",
        "            \"reference_keywords\": prompt_meta.get(\"reference_keywords\", []),\n",
        "\n",
        "            # sympy input screen\n",
        "            \"sympy_screen_input\": sympy_first_screening_on_item(item),\n",
        "\n",
        "            # LLM 결과\n",
        "            \"retry_count\": result.get(\"retry_count\", 0),\n",
        "            \"elapsed_sec\": round(elapsed_sec, 3),\n",
        "            \"success\": success,\n",
        "            \"valid_payload\": valid_payload,\n",
        "            \"objective_match\": objective_match,\n",
        "            \"reference_match\": reference_match,\n",
        "            \"sympy_equivalent_to_reference_answer\": sympy_eq,\n",
        "            \"quality_flags\": result.get(\"quality_flags\", {}),\n",
        "\n",
        "            # raw output\n",
        "            \"llm_raw_output\": result.get(\"raw_output\", \"\"),\n",
        "\n",
        "            # parsed payload\n",
        "            \"llm_problem_type\": payload.get(\"problem_type\", \"\"),\n",
        "            \"llm_is_subjective_fit\": payload.get(\"is_subjective_fit\", \"\"),\n",
        "            \"llm_is_objective_fit\": payload.get(\"is_objective_fit\", \"\"),\n",
        "            \"llm_is_three_digit_integer_answer\": payload.get(\"is_three_digit_integer_answer\", \"\"),\n",
        "            \"llm_is_unique_answer\": payload.get(\"is_unique_answer\", \"\"),\n",
        "            \"llm_sympy_verifiable\": payload.get(\"sympy_verifiable\", \"\"),\n",
        "            \"llm_reasoning_steps\": payload.get(\"reasoning_steps\", \"\"),\n",
        "            \"llm_explanation\": payload.get(\"explanation\", \"\"),\n",
        "            \"llm_final_answer\": payload.get(\"final_answer\", \"\"),\n",
        "            \"llm_choices\": payload.get(\"choices\", \"\"),\n",
        "            \"llm_correct_choice\": payload.get(\"correct_choice\", \"\"),\n",
        "        }\n",
        "        rows.append(row)\n",
        "\n",
        "        print(\n",
        "            f\"[TEST] idx={i:03d} \"\n",
        "            f\"source_item_id={row['source_item_id']} \"\n",
        "            f\"level={lvl} \"\n",
        "            f\"retry={row['retry_count']} \"\n",
        "            f\"success={success} \"\n",
        "            f\"sympy_eq={sympy_eq} \"\n",
        "            f\"elapsed={elapsed_sec:.2f}s\"\n",
        "        )\n",
        "\n",
        "    total_elapsed = time.perf_counter() - total_start\n",
        "    n = len(rows)\n",
        "\n",
        "    # 상세 저장\n",
        "    with result_json.open(\"w\", encoding=\"utf-8\") as f:\n",
        "        json.dump(rows, f, ensure_ascii=False, indent=2)\n",
        "\n",
        "    flat_rows = []\n",
        "    for r in rows:\n",
        "        p = r.get(\"payload\", {})\n",
        "        flat_rows.append(\n",
        "            {\n",
        "                \"idx\": r[\"idx\"],\n",
        "                \"source_item_id\": r[\"source_item_id\"],\n",
        "                \"level_id\": r[\"level_id\"],\n",
        "                \"subject\": r[\"subject\"],\n",
        "                \"chapter\": r[\"chapter\"],\n",
        "                \"unit\": r[\"unit\"],\n",
        "                \"problem_type_detected\": r[\"problem_type_detected\"],\n",
        "\n",
        "                \"retry_count\": r[\"retry_count\"],\n",
        "                \"elapsed_sec\": r[\"elapsed_sec\"],\n",
        "                \"success\": r[\"success\"],\n",
        "                \"valid_payload\": r[\"valid_payload\"],\n",
        "                \"objective_match\": r[\"objective_match\"],\n",
        "                \"reference_match\": r[\"reference_match\"],\n",
        "                \"sympy_equivalent_to_reference_answer\": r[\"sympy_equivalent_to_reference_answer\"],\n",
        "\n",
        "                # test 문항\n",
        "                \"exam_text\": r[\"exam_text\"],\n",
        "\n",
        "                # 모범답안\n",
        "                \"reference_answer_text\": r[\"reference_answer_text\"],\n",
        "                \"reference_explanation_text\": r[\"reference_explanation_text\"],\n",
        "\n",
        "                # llm 결과\n",
        "                \"llm_problem_type\": r[\"llm_problem_type\"],\n",
        "                \"llm_is_subjective_fit\": r[\"llm_is_subjective_fit\"],\n",
        "                \"llm_is_objective_fit\": r[\"llm_is_objective_fit\"],\n",
        "                \"llm_is_three_digit_integer_answer\": r[\"llm_is_three_digit_integer_answer\"],\n",
        "                \"llm_is_unique_answer\": r[\"llm_is_unique_answer\"],\n",
        "                \"llm_sympy_verifiable\": r[\"llm_sympy_verifiable\"],\n",
        "                \"llm_final_answer\": r[\"llm_final_answer\"],\n",
        "                \"llm_correct_choice\": r[\"llm_correct_choice\"],\n",
        "                \"llm_reasoning_steps\": r[\"llm_reasoning_steps\"],\n",
        "                \"llm_explanation\": r[\"llm_explanation\"],\n",
        "                \"llm_choices\": r[\"llm_choices\"],\n",
        "\n",
        "                # raw\n",
        "                \"llm_raw_output\": r[\"llm_raw_output\"],\n",
        "            }\n",
        "        )\n",
        "\n",
        "    result_table_path = save_dataframe_with_fallback(pd.DataFrame(flat_rows), result_xlsx)\n",
        "\n",
        "    summary_payload = {\n",
        "        \"target_id\": args.target_id,\n",
        "        \"input_json\": args.input_json,\n",
        "        \"ref_json\": args.ref_json,\n",
        "        \"level_id\": args.level_id if args.level_id != -1 else \"all\",\n",
        "        \"n_tests\": n,\n",
        "        \"total_elapsed_sec\": round(total_elapsed, 3),\n",
        "        \"avg_elapsed_sec_per_item\": round(total_elapsed / n, 3) if n > 0 else 0.0,\n",
        "        \"success_count\": success_count,\n",
        "        \"success_rate_percent\": round(success_count / n * 100, 3) if n > 0 else 0.0,\n",
        "        \"valid_payload_count\": valid_payload_count,\n",
        "        \"valid_payload_rate_percent\": round(valid_payload_count / n * 100, 3) if n > 0 else 0.0,\n",
        "        \"objective_match_count\": objective_match_count,\n",
        "        \"objective_match_rate_percent\": round(objective_match_count / n * 100, 3) if n > 0 else 0.0,\n",
        "        \"reference_match_count\": reference_match_count,\n",
        "        \"reference_match_rate_percent\": round(reference_match_count / n * 100, 3) if n > 0 else 0.0,\n",
        "        \"sympy_equivalent_count\": sympy_equiv_count,\n",
        "        \"sympy_equivalent_rate_percent\": round(sympy_equiv_count / n * 100, 3) if n > 0 else 0.0,\n",
        "        \"problem_type_distribution\": problem_type_counter,\n",
        "        \"level_distribution\": level_counter,\n",
        "        \"levels\": [\n",
        "            {\n",
        "                \"target_id\": args.target_id,\n",
        "                \"level_id\": args.level_id if args.level_id != -1 else \"all\",\n",
        "                \"n_tests\": n,\n",
        "                \"success_count\": success_count,\n",
        "                \"success_rate_percent\": round(success_count / n * 100, 3) if n > 0 else 0.0,\n",
        "                \"valid_payload_count\": valid_payload_count,\n",
        "                \"valid_payload_rate_percent\": round(valid_payload_count / n * 100, 3) if n > 0 else 0.0,\n",
        "                \"reference_match_count\": reference_match_count,\n",
        "                \"reference_match_rate_percent\": round(reference_match_count / n * 100, 3) if n > 0 else 0.0,\n",
        "                \"sympy_equivalent_count\": sympy_equiv_count,\n",
        "                \"sympy_equivalent_rate_percent\": round(sympy_equiv_count / n * 100, 3) if n > 0 else 0.0,\n",
        "                \"avg_elapsed_sec_per_item\": round(total_elapsed / n, 3) if n > 0 else 0.0,\n",
        "            }\n",
        "        ],\n",
        "    }\n",
        "\n",
        "    with summary_json.open(\"w\", encoding=\"utf-8\") as f:\n",
        "        json.dump(summary_payload, f, ensure_ascii=False, indent=2)\n",
        "\n",
        "    summary_table_path = save_dataframe_with_fallback(\n",
        "        pd.DataFrame(summary_payload[\"levels\"]),\n",
        "        summary_xlsx,\n",
        "    )\n",
        "\n",
        "    unload_model(model, tokenizer)\n",
        "\n",
        "    print(f\"[DONE] result_json: {result_json}\")\n",
        "    print(f\"[DONE] result_table: {result_table_path}\")\n",
        "    print(f\"[DONE] summary_json: {summary_json}\")\n",
        "    print(f\"[DONE] summary_table: {summary_table_path}\")\n",
        "    print(\n",
        "        f\"[DONE] sympy_equivalent_rate={summary_payload['sympy_equivalent_rate_percent']:.2f}% \"\n",
        "        f\"reference_match_rate={summary_payload['reference_match_rate_percent']:.2f}% \"\n",
        "        f\"success_rate={summary_payload['success_rate_percent']:.2f}%\"\n",
        "    )\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    main()"
      ]
    }
  ]
